{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "type": "chrome",
            "request": "launch",
            "name": "Launch Chromium against Vite",
            "url": "http://127.0.0.1:5173",
            "webRoot": "${workspaceFolder}",
            "runtimeExecutable": "C:\\Tools\\ChromiumPortable\\ChromiumPortable.exe",
            "runtimeArgs": [
                "--remote-debugging-port=9222",
                "--user-data-dir=${workspaceFolder}\\.vscode\\vscode-chromium-profile"
            ],
            "sourceMaps": true,
            "smartStep": true,
            "skipFiles": [
                "${workspaceFolder}/node_modules/**/*.js",
                "${workspaceFolder}/node_modules/**/*.mjs",
                "**/node_modules/**",
                "**/*.wasm",
                "data:**"
            ],
            "resolveSourceMapLocations": [
                "${workspaceFolder}/src/**",
                "${workspaceFolder}/index.html",
                "!**/node_modules/**",
                "!**/*.wasm",
                "!data:**"
            ],
            "timeout": 30000,
            "preLaunchTask": "vite: dev",
            "postDebugTask": "vite: stop"
        },
        {
            "name": "Launch Firefox Dev Edition against Vite",
            "type": "firefox",
            "request": "launch",
            "url": "http://127.0.0.1:5173",
            "webRoot": "${workspaceFolder}",
            "firefoxExecutable": "C:\\Tools\\FirefoxPortableDeveloper\\App\\Firefox64\\firefox.exe",
            "reAttach": true,
            // "profile": "${workspaceFolder}\\.vscode\\firefox-debug-profile",
            // "keepProfileChanges": false,
            // "port": 6000,
            "preLaunchTask": "vite: dev",
            "postDebugTask": "vite: stop"
        },
        {
            "name": "Attach Firefox Dev Edition",
            "type": "firefox",
            "request": "attach",
            "firefoxExecutable": "C:\\Tools\\FirefoxPortableDeveloper\\App\\Firefox64\\firefox.exe"
        }
    ]
}